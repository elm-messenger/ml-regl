(executable
 (name test_ml_regl)
 (modules test_ml_regl)
 (libraries js_of_ocaml ml_regl_js)
 (modes js)
 (preprocess
  (pps js_of_ocaml-ppx))
 (flags
  (:standard -warn-error -A))
 (js_of_ocaml
  (flags
   (:standard --opt=3))))

