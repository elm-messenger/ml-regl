; --- test_fbo_grow: cross-backend dynamic FBO pool growth --------------
; Seeds the pool with [fbo_num = 1] and renders a tree that needs many
; concurrent palettes per frame. Both backends (JS allocNewFBO; desktop
; FboPool::acquire grow path) must dynamically grow the pool or the
; visible output will be missing sub-trees.

(executable
 (name test_fbo_grow)
 (modules test_fbo_grow)
 (libraries js_of_ocaml ml_regl_js)
 (modes js)
 (preprocess
  (pps js_of_ocaml-ppx))
 (flags
  (:standard -warn-error -A))
 (js_of_ocaml
  (flags
   (:standard --opt=3))))

(executable
 (name test_fbo_grow_desktop)
 (modules test_fbo_grow_desktop)
 (libraries ml_regl_desktop)
 (modes
  (native exe))
 (flags
  (:standard -warn-error -A)))

(rule
 (target test_fbo_grow_desktop.ml)
 (deps test_fbo_grow.ml)
 (action
  (copy %{deps} %{target})))
